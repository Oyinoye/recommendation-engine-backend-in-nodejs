{
  "name": "segment-to-context-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Event ingestion and AI context worker (Express + TypeScript)",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "worker": "tsx src/worker.ts",
    "seed": "tsx src/scripts/seed.ts",
    "test": "jest --coverage",
    "test:integration": "jest --runInBand --testPathPattern=integration",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=lcov"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^4.3.3",
    "@google-cloud/vertexai": "^1.9.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "pg": "^8.12.0",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
